# MEIC Bot Configuration
# Never commit real values to this file

# PAPER MODE (Practice/Sandbox)
# For development and testing without real money
PAPER_MODE=true

# Panel password (required for live mode)
PANEL_PASSWORD=your_secure_password_here

# Tastytrade Credentials (required for live trading)
# Paper account credentials:
TT_PAPER_PROVIDER_SECRET=your_paper_secret
TT_PAPER_REFRESH_TOKEN=your_paper_refresh_token
TT_PAPER_ACCOUNT=your_paper_account

# Live account credentials (only needed for real trading):
TT_LIVE_PROVIDER_SECRET=your_live_secret
TT_LIVE_REFRESH_TOKEN=your_live_refresh_token
TT_LIVE_ACCOUNT=your_live_account

# Certification/Testing (contract tests only):
TT_CERT_PROVIDER_SECRET=your_cert_secret
TT_CERT_REFRESH_TOKEN=your_cert_refresh_token
TT_CERT_ACCOUNT=your_cert_account

# Optional: Calendar sync (for trading calendar/holidays)
CALENDAR_SOURCE_URL=
CALENDAR_REFRESH_INTERVAL_HOURS=24
